<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Myary.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Myary"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Myary">

    <NavigationView Background="#FFF8F0"  PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="True"
                    IsSettingsVisible="False"
                    OpenPaneLength="180"
                    CompactPaneLength="50">

        <NavigationView.Resources>
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#D6A2A8"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="Black"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="Black"/>
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="Black"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#E7C6C9"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#F1E9E9"/>
        </NavigationView.Resources>
        
        <NavigationView.MenuItems>

                <NavigationViewItem Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Favorites" Tag="Favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <Grid Background="#FFF8F0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" x:Name="RightSidebarColumn"/>
                </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F1E9E9" Padding="20">
                    <Grid>
                        <TextBlock Text="{x:Bind ViewModel.FormattedSelectedDate, Mode=OneWay}"
                                       Foreground="#363537"
                                   FontWeight="Bold" FontSize="20"
                                   VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10">
                            
                            <!--
                            <Button ToolTipService.ToolTip="Set Day Background">
                                <Button.Content>
                                    <FontIcon Glyph="&#xE2B1;" FontSize="14"/>
                                </Button.Content>
                            </Button>
                            -->
                            
                            <Button Content="+ Add Entry" Background="#D6A2A8"
                                    Foreground="#363537" FontWeight="SemiBold" 
                                        Command="{x:Bind ViewModel.AddEntryCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--
                    <StackPanel Grid.Row="1" Padding="20,10" Spacing="10"
                            BorderBrush="#F1E9E9" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Dream Journal" Background="#E7C6C9" BorderThickness="0"/>
                            <Button Content="Today's Inspiration" Background="Transparent" BorderThickness="0"/>
                            <Button Content="Anxiety Reasons" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                    */
                    -->

                <ListView x:Name="TabBar" Grid.Row="1" 
                          ItemsSource="{x:Bind ViewModel.CurrentDayEntries, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.ActiveEntry, Mode=TwoWay}"
                          SelectionMode="Single"
                          Height="60"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            >
                    
                    <ListView.Resources>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#E7C6C9"/>
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#D6A2A8"/>
                        <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent"/>
                    </ListView.Resources>
                    
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Padding="20,10" Orientation="Horizontal" 
                                        Spacing="10" BorderBrush="#F1E9E9"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Title}" Foreground="#363537" VerticalAlignment="Center"/>
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Delete Note"
                                                        Icon="Delete"
                                                        Foreground="Red"
                                                        Click="DeleteNote_Click"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
              
                    <Grid Grid.Row="2" Padding="20">
                        <RichEditBox x:Name="DiaryEditor"
                                     HorizontalAlignment="Stretch" 
                                     VerticalAlignment="Stretch"
                                     PlaceholderText="Share your feelings and photos here..."
                                     BorderThickness="0"
                                     Padding="20,20,20,80"
                                     AllowDrop="True"
                                     DragOver="DiaryEditor_DragOver"
                                     Drop="DiaryEditor_Drop"
                                     LostFocus="DiaryEditor_LostFocus"
                         />

                        <Border VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Background="#F1E9E9" CornerRadius="8"
                            Padding="10" Margin="10" BorderBrush="#F1E9E9" BorderThickness="1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <ComboBox SelectionChanged="FontBox_SelectionChanged" SelectedIndex="0" Width="140" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Segoe Print"/>
                                    <ComboBoxItem Content="Courier New"/>
                                    <ComboBoxItem Content="Futura"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Georgia"/>
                                    </ComboBox>

                                    <ComboBox SelectionChanged="FontSizeBox_SelectionChanged" SelectedIndex="1" Width="70" VerticalAlignment="Center">
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="16"/>
                                </ComboBox>

                                    <AppBarSeparator Margin="5,0"/>

                                    <Button Content="B" Click="BoldButton_Click" FontWeight="Bold" Width="40"/>
                                    <Button Content="I" Click="ItalicButton_Click" FontStyle="Italic" Width="40"/>
                                    <Button Click="UnderlineButton_Click" Width="40">
                                        <Button.Content>
                                            <TextBlock Text="U" TextDecorations="Underline"/>
                                        </Button.Content>
                                    </Button>

                                    <AppBarSeparator Margin="5,0"/>

                                    <Button ToolTipService.ToolTip="Text Color">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xE790;" FontSize="16"/>
                                        </Button.Content>
                                    </Button>

                                    <Button ToolTipService.ToolTip="Highlighter">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xE7E6;" FontSize="16"/>
                                        </Button.Content>
                                    </Button>

                                <AppBarSeparator Margin="5,0"/>

                                <Button ToolTipService.ToolTip="Insert Image">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xEB9F;" FontSize="16"/>
                                        </Button.Content>
                                    </Button>
                                    <Button ToolTipService.ToolTip="Insert Audio">
                                        <Button.Content>
                                            <FontIcon Glyph="&#xE720;" FontSize="16"/>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Column="1" Background="#F1E9E9" 
                    BorderBrush="#F1E9E9" BorderThickness="1,0,0,0">
                        <Grid Padding="10">

                    <Grid.Resources>
                        <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#D6A2A8"/>
                        <SolidColorBrush x:Key="SystemControlHighlightAccentLowBrush" Color="#E7C6C9"/>
                        <SolidColorBrush x:Key="SystemControlHighlightAccentMediumBrush" Color="#D6A2A8"/>
                        <SolidColorBrush x:Key="SystemControlHighlightAccentHighBrush" Color="#D6A2A8"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#E7C6C9"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#D6A2A8"/>
                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#E7C6C9"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#363537"/>
                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#363537"/>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToggleButton x:Name="ToggleRightPaneButton"
                                  ToolTipService.ToolTip="Toggle Sidebar"
                                  IsChecked="True"
                                  Click="ToggleRightPane_Click"
                                  HorizontalAlignment="Left"
                                  Grid.Row="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="0,0,0,15">
                            <FontIcon Glyph="&#xE8A4;" FontSize="16"/>
                        </ToggleButton>

                        <Grid x:Name="RightSidebarContent" Grid.Row="1" Width="290">
                            <Viewbox VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,70">
                                <CalendarView x:Name="DayCalendar"
                                              Background="#B1FFFFFF"
                                              IsOutOfScopeEnabled="False"
                                              SelectedDatesChanged="DayCalendar_SelectedDatesChanged"
                                              DayOfWeekFormat="{}{dayofweek.abbreviated(1)}"
                                              SelectionMode="Single"
                                              />
                            </Viewbox>

                            <Button x:Name="RandomEntryButton"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Height="50"
                            CornerRadius="8"
                            Background="#D6A2A8"
                            Foreground="#363537"
                            Margin="5">
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                        HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE8B1;" FontSize="16"/>
                                    <TextBlock Text="Open Random Entry"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
    </NavigationView>
</Window>
