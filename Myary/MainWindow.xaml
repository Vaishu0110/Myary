<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Myary.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Myary"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Myary">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" x:Name="LeftSidebarColumn"/>
            
            <ColumnDefinition Width="*"/>
            
            <ColumnDefinition Width="Auto" x:Name="RightSidebarColumn"/>
        </Grid.ColumnDefinitions>

        <NavigationView Grid.Column="0"
                        HorizontalAlignment="Left"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="True"
                        IsSettingsVisible="False"
                        OpenPaneLength="250"
                        CompactPaneLength="48">

            <NavigationView.MenuItems>
                
                <NavigationViewItem Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Favorites" Tag="Favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
            </NavigationView.MenuItems>
        
        </NavigationView>

        <Grid Grid.Column="1" Background="#FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F0F8FF" Padding="20">
                <Grid>
                    <TextBlock Text="09 April 2026"
                               FontWeight="Bold" FontSize="20"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <Button ToolTipService.ToolTip="Set Day Background">
                            <Button.Content>
                                <FontIcon Glyph="&#xE2B1;" FontSize="14"/>
                            </Button.Content>
                        </Button>

                        <Button Content="+ Add Entry" Background="#005FB8"
                                Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Padding="20,10" Spacing="10"
                        BorderBrush="#EAEAEA" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Morning Thoughts" Background="#EAEAEA"/>
                    <Button Content="Work Notes" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
                <Grid>
                    <TextBlock Text="Created: 08:00 AM | Updated 08:15 AM"
                               Foreground="#888888" HorizontalAlignment="Right"
                               VerticalAlignment="Bottom" FontSize="12"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="2" Padding="20">
                <RichEditBox x:Name="DiaryEditor"
                             HorizontalAlignment="Stretch" 
                             VerticalAlignment="Stretch"
                             PlaceholderText="Share your feelings and photos here..."
                             BorderThickness="0"
                             Padding="20,20,20,80"/>

                <Border VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Background="#FAFAFA" CornerRadius="8"
                        Padding="10" Margin="10" BorderBrush="#EAEAEA" BorderThickness="1">
                    
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <ComboBox SelectedIndex="0" Width="140" VerticalAlignment="Center">
                            <ComboBoxItem Content="Seoge UI"/>
                            <ComboBoxItem Content="Arial"/>
                            <ComboBoxItem Content="Georgia"/>
                        </ComboBox>

                        <ComboBox SelectedIndex="1" Width="70" VerticalAlignment="Center">
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="14"/>
                            <ComboBoxItem Content="18"/>
                        </ComboBox>

                        <AppBarSeparator Margin="5,0"/>

                        <Button Content="B" FontWeight="Bold" Width="40"/>
                        <Button Content="I" FontStyle="Italic" Width="40"/>
                        <Button Width="40" Background="Transparent">
                            <Button.Content>
                                <TextBlock Text="U" TextDecorations="Underline"/>
                            </Button.Content>
                        </Button>

                        <AppBarSeparator Margin="5,0"/>

                        <Button ToolTipService.ToolTip="Insert Image">
                            <Button.Content>
                                <FontIcon Glyph="&#xEB9F;" FontSize="16"/>
                            </Button.Content>
                        </Button>
                        <Button ToolTipService.ToolTip="Insert Audio">
                            <Button.Content>
                                <FontIcon Glyph="&#xE720;" FontSize="16"/>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Column="2" Background="#F9F9F9" 
                BorderBrush="#EAEAEA" BorderThickness="1,0,0,0">
            <Grid Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ToggleButton x:Name="ToggleRightPaneButton"
                              ToolTipService.ToolTip="Toggle Sidebar"
                              IsChecked="True"
                              Click="ToggleRightPane_Click"
                              HorizontalAlignment="Left"
                              Grid.Row="0"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,0,0,15">
                    <FontIcon Glyph="&#xE8A4;" FontSize="16"/>
                </ToggleButton>

                <Grid x:Name="RightSidebarContent" Grid.Row="1" Width="290">
                    <Viewbox VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,70">
                        <CalendarView x:Name="DayCalendar"
                            IsOutOfScopeEnabled="False"
                            DayOfWeekFormat="{}{dayofweek.abbreviated(1)}"/>
                    </Viewbox>

                    <Button x:Name="RandomEntryButton"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Height="50"
                        CornerRadius="8"
                        Background="#005FB8"
                        Foreground="White"
                        Margin="5">
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8B1;" FontSize="16"/>
                            <TextBlock Text="Open Random Entry"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
